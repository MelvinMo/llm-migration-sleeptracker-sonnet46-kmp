# Kotlin does not auto-load .env files.
# Apply these values manually in:
#   composeApp/src/commonMain/kotlin/com/sleeptracker/network/HttpApiClient.kt
#
# For production:  set DEFAULT_BACKEND_URL = BACKEND_URL below
# For local dev:   DEFAULT_BACKEND_URL = "http://10.0.2.2:7000/api"  (emulator -> host localhost)
#                  DEFAULT_BACKEND_URL = "http://your-local-ip:7000/api"  (physical device -> LAN)

# Copy this file to .env and fill in your own backend URL.
# Never commit the real .env file -- it is already in .gitignore.

BACKEND_URL=https://your-backend-host.example.com/api
